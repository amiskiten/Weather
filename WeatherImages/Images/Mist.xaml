<UserControl x:Class="Weather.WeatherImages.Images.Mist"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.WeatherImages.Images"
             xmlns:elems="clr-namespace:Weather.WeatherImages.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Viewbox>
        <Canvas Width="64" Height="64">
            <elems:FogLine AnimationBeginTime="0:0:0" LineTopMargin="23.5"/>
            <elems:FogLine AnimationBeginTime="-0:0:2" LineTopMargin="30.5"/>
            <elems:FogLine AnimationBeginTime="-0:0:4" LineTopMargin="37.5"/>
        </Canvas>
    </Viewbox>
</UserControl>
