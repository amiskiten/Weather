<UserControl x:Class="Weather.WeatherImages.Images.Hail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.WeatherImages.Images"
             xmlns:elems="clr-namespace:Weather.WeatherImages.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Viewbox>
        <Canvas Width="64" Height="64">
            <Rectangle Fill="{StaticResource CloudDrawing}" Height="64" Width="64"/>
            <Ellipse x:Name="drop1"
                     Width="3" Height="3"
                     Fill="{StaticResource HailDropGradient}"
                     Canvas.Left="22.5" Canvas.Top="42">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="trans1" X="1" Y="-5" />
                </Ellipse.RenderTransform>
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="trans1" Storyboard.TargetProperty="X" Duration="0:0:0.6">
                                    <LinearDoubleKeyFrame Value="1"  KeyTime="0:0:0" />
                                    <LinearDoubleKeyFrame Value="-2" KeyTime="0:0:0.3" />
                                    <LinearDoubleKeyFrame Value="-4" KeyTime="0:0:0.6" />
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="trans1" Storyboard.TargetProperty="Y" Duration="0:0:0.6">
                                    <LinearDoubleKeyFrame Value="-5" KeyTime="0:0:0" />
                                    <LinearDoubleKeyFrame Value="18" KeyTime="0:0:0.3" />
                                    <LinearDoubleKeyFrame Value="14" KeyTime="0:0:0.6" />
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="drop1" Storyboard.TargetProperty="Opacity" Duration="0:0:0.6">
                                    <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0" />
                                    <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.3" />
                                    <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.6" />
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <Ellipse x:Name="drop2"
                     Width="3" Height="3"
                     Fill="{StaticResource HailDropGradient}"
                     Canvas.Left="29.5" Canvas.Top="42">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="trans2" X="-2.67" Y="16.67" />
                </Ellipse.RenderTransform>
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" BeginTime="-0:0:0.4">
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="trans2" Storyboard.TargetProperty="X" Duration="0:0:0.6">
                                    <LinearDoubleKeyFrame Value="1"  KeyTime="0:0:0" />
                                    <LinearDoubleKeyFrame Value="-2" KeyTime="0:0:0.3" />
                                    <LinearDoubleKeyFrame Value="-4" KeyTime="0:0:0.6" />
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="trans2" Storyboard.TargetProperty="Y" Duration="0:0:0.6">
                                    <LinearDoubleKeyFrame Value="-5" KeyTime="0:0:0" />
                                    <LinearDoubleKeyFrame Value="18" KeyTime="0:0:0.3" />
                                    <LinearDoubleKeyFrame Value="14" KeyTime="0:0:0.6" />
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="drop2" Storyboard.TargetProperty="Opacity" Duration="0:0:0.6">
                                    <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0" />
                                    <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.3" />
                                    <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.6" />
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <Ellipse x:Name="drop3"
                     Width="3" Height="3"
                     Fill="{StaticResource HailDropGradient}"
                     Canvas.Left="36.5" Canvas.Top="42">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="trans3" X="-1" Y="10.33" />
                </Ellipse.RenderTransform>
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" BeginTime="-0:0:0.2">
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="trans3" Storyboard.TargetProperty="X" Duration="0:0:0.6">
                                    <LinearDoubleKeyFrame Value="1"  KeyTime="0:0:0" />
                                    <LinearDoubleKeyFrame Value="-2" KeyTime="0:0:0.3" />
                                    <LinearDoubleKeyFrame Value="-4" KeyTime="0:0:0.6" />
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="trans3" Storyboard.TargetProperty="Y" Duration="0:0:0.6">
                                    <LinearDoubleKeyFrame Value="-5" KeyTime="0:0:0" />
                                    <LinearDoubleKeyFrame Value="18" KeyTime="0:0:0.3" />
                                    <LinearDoubleKeyFrame Value="14" KeyTime="0:0:0.6" />
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="drop3" Storyboard.TargetProperty="Opacity" Duration="0:0:0.6">
                                    <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0" />
                                    <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.3" />
                                    <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.6" />
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
        </Canvas>
    </Viewbox>
</UserControl>

