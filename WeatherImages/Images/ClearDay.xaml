<UserControl x:Class="Weather.WeatherImages.Images.ClearDay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.WeatherImages.Images"
             xmlns:elems="clr-namespace:Weather.WeatherImages.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Viewbox>
        <Canvas Width="64" Height="64">

            <Ellipse Canvas.Left="21.5" Canvas.Top="21.5"
         Width="21" Height="21"
         Fill="{StaticResource ClearSunGradient}"
         Stroke="#F8AF18" StrokeThickness="0.5"/>

            <Path Data="M32,15.71 V9.5 m0,45 v-6.21 m11.52,-27.81 l4.39,-4.39 M16.09,47.91 l4.39,-4.39 m0,-23 l-4.39,-4.39 m31.82,31.78 l-4.39,-4.39 M15.71,32 H9.5 m45,0 h-6.21"
      Stroke="#FBBF24" StrokeThickness="3"
      StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                <Path.RenderTransform>
                    <RotateTransform CenterX="32" CenterY="32" x:Name="rotateTransform"/>
                </Path.RenderTransform>
                <Path.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="rotateTransform"
                           Storyboard.TargetProperty="Angle"
                           From="0" To="360" Duration="0:0:45"
                           RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Path.Triggers>
            </Path>
        </Canvas>
    </Viewbox>
</UserControl>

