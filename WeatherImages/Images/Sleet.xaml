<UserControl x:Class="Weather.WeatherImages.Images.Sleet"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.WeatherImages.Images"
             xmlns:elems="clr-namespace:Weather.WeatherImages.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="gear1Move"
                                                   Storyboard.TargetProperty="X"
                                                   BeginTime="-0:0:2"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="1"  KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="-1" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="gear1Move"
                                                   Storyboard.TargetProperty="Y"
                                                   BeginTime="-0:0:2"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="-6" KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="12" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimation Storyboard.TargetName="gear1Rot"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:9"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="gear1Container"
                                                   Storyboard.TargetProperty="Opacity"
                                                   BeginTime="-0:0:2"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:1"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:2"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:3"/>
                        <LinearDoubleKeyFrame Value="0" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="gear2Move"
                                                   Storyboard.TargetProperty="X"
                                                   BeginTime="-0:0:1"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="1"  KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="-1" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="gear2Move"
                                                   Storyboard.TargetProperty="Y"
                                                   BeginTime="-0:0:1"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="-6" KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="12" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimation Storyboard.TargetName="gear2Rot"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:9"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="gear2Container"
                                                   Storyboard.TargetProperty="Opacity"
                                                   BeginTime="-0:0:1"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:1"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:2"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:3"/>
                        <LinearDoubleKeyFrame Value="0" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Viewbox>
        <Canvas Width="64" Height="64">
            <Rectangle Fill="{StaticResource CloudDrawing}" Height="64" Width="64"/>
            <Canvas x:Name="gear1Container">
                <Canvas.RenderTransform>
                    <TranslateTransform x:Name="gear1Move"/>
                </Canvas.RenderTransform>
                <Canvas>
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="gear1Rot" CenterX="24" CenterY="45"/>
                    </Canvas.RenderTransform>
                    <Ellipse Width="2.5" Height="2.5"
                             Canvas.Left="22.75" Canvas.Top="43.75"
                             Stroke="{StaticResource Gear1CircleStroke}"
                             StrokeThickness="1" StrokeMiterLimit="10"/>
                    <Path Data="M26.17 46.25 l-1.09 -0.63 m-2.16 -1.24 l-1.09 -0.63 M24 42.5 v1.25 m0 3.75 v-1.25 m-1.08 -0.63 l-1.09 0.63 m4.34 -2.5 l-1.09 0.63"
                          Stroke="{StaticResource Gear1RaysStroke}"
                          StrokeThickness="1" StrokeMiterLimit="10"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                </Canvas>
            </Canvas>
            <Canvas x:Name="gear2Container">
                <Canvas.RenderTransform>
                    <TranslateTransform x:Name="gear2Move"/>
                </Canvas.RenderTransform>
                <Canvas>
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="gear2Rot" CenterX="38" CenterY="45"/>
                    </Canvas.RenderTransform>
                    <Ellipse Width="2.5" Height="2.5"
                             Canvas.Left="36.75" Canvas.Top="43.75"
                             Stroke="{StaticResource Gear2CircleStroke}"
                             StrokeThickness="1" StrokeMiterLimit="10"/>
                    <Path Data="M40.17 46.25 l-1.09 -0.63 m-2.16 -1.24 l-1.09 -0.63 M38 42.5 v1.25 m0 3.75 v-1.25 m-1.08 -0.63 l-1.09 0.63 m4.34 -2.5 l-1.09 0.63"
                          Stroke="{StaticResource Gear2RaysStroke}"
                          StrokeThickness="1" StrokeMiterLimit="10"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                </Canvas>
            </Canvas>
            <elems:DrizzleRaindrops/>
        </Canvas>
    </Viewbox>
</UserControl>

