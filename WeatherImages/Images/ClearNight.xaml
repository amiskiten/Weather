<UserControl x:Class="Weather.WeatherImages.Images.ClearNight"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.WeatherImages.Images"
             xmlns:elems="clr-namespace:Weather.WeatherImages.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Viewbox>
        <Canvas Width="64" Height="64">
            <Path Data="M46.66 36.2 a16.66 16.66 0 0 1 -16.78 -16.55 a16.29 16.29 0 0 1 0.55 -4.15 A16.56 16.56 0 1 0 48.5 36.1 c-0.61 0.06 -1.22 0.1 -1.84 0.1 z"
                  Stroke="#72B9D5"
                  StrokeThickness="0.5"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round">
                <Path.Fill>
                    <LinearGradientBrush MappingMode="Absolute"
                                         StartPoint="21.92,18.75"
                                         EndPoint="38.52,47.52">
                        <LinearGradientBrush.Transform>
                            <RotateTransform x:Name="GradientRotate" Angle="5" CenterX="32" CenterY="32" />
                        </LinearGradientBrush.Transform>
                        <GradientStop Offset="0"   Color="#86C3DB" />
                        <GradientStop Offset="0.45" Color="#86C3DB" />
                        <GradientStop Offset="1"   Color="#5EAFCF" />
                    </LinearGradientBrush>
                </Path.Fill>
                <Path.RenderTransform>
                    <RotateTransform x:Name="PathRotate" Angle="-5" CenterX="32" CenterY="32" />
                </Path.RenderTransform>
            </Path>
        </Canvas>
    </Viewbox>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation 
                        Storyboard.TargetName="GradientRotate"
                        Storyboard.TargetProperty="Angle"
                        From="5" To="-15"
                        Duration="0:0:5"
                        AutoReverse="True"
                        RepeatBehavior="Forever" />

                    <DoubleAnimation 
                        Storyboard.TargetName="PathRotate"
                        Storyboard.TargetProperty="Angle"
                        From="-5" To="15"
                        Duration="0:0:5"
                        AutoReverse="True"
                        RepeatBehavior="Forever" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
