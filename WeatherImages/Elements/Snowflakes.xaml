<UserControl x:Class="Weather.WeatherImages.Elements.Snowflakes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.WeatherImages.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="snow1Move"
                                                   Storyboard.TargetProperty="X"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="-1" KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="1"  KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="snow1Move"
                                                   Storyboard.TargetProperty="Y"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="-6" KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="12" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>

                    <DoubleAnimation Storyboard.TargetName="snow1Rot"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:9"
                                     RepeatBehavior="Forever"/>

                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="snow1Container"
                                                   Storyboard.TargetProperty="Opacity"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:1"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:2"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:3"/>
                        <LinearDoubleKeyFrame Value="0" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="snow2Move"
                                                   Storyboard.TargetProperty="X"
                                                   BeginTime="-0:0:2"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="1"  KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="-1" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="snow2Move"
                                                   Storyboard.TargetProperty="Y"
                                                   BeginTime="-0:0:2"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="-6" KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="12" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>

                    <DoubleAnimation Storyboard.TargetName="snow2Rot"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:9"
                                     RepeatBehavior="Forever"/>

                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="snow2Container"
                                                   Storyboard.TargetProperty="Opacity"
                                                   BeginTime="-0:0:2"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:1"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:2"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:3"/>
                        <LinearDoubleKeyFrame Value="0" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="snow3Move"
                                                   Storyboard.TargetProperty="X"
                                                   BeginTime="-0:0:1"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="1"  KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="-1" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="snow3Move"
                                                   Storyboard.TargetProperty="Y"
                                                   BeginTime="-0:0:1"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="-6" KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="12" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>

                    <DoubleAnimation Storyboard.TargetName="snow3Rot"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:9"
                                     RepeatBehavior="Forever"/>

                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="snow3Container"
                                                   Storyboard.TargetProperty="Opacity"
                                                   BeginTime="-0:0:1"
                                                   RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:1"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:2"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="0:0:3"/>
                        <LinearDoubleKeyFrame Value="0" KeyTime="0:0:4"/>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>


    <Canvas Width="64" Height="64">
        <Canvas x:Name="snow1Container">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="snow1Move"/>
            </Canvas.RenderTransform>
            <Canvas>
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="snow1Rot" CenterX="31" CenterY="45"/>
                </Canvas.RenderTransform>
                <Ellipse Width="2.5" Height="2.5"
                     Canvas.Left="29.75" Canvas.Top="43.75"
                     Stroke="{StaticResource snow1Circle}"
                     StrokeThickness="1" StrokeMiterLimit="10"/>
                <Path Data="M33.17 46.25 l-1.09 -0.63 m-2.16 -1.24 l-1.09 -0.63 M31 42.5 v1.25 m0 3.75 v-1.25 m-1.08 -0.63 l-1.09 0.63 m4.34 -2.5 l-1.09 0.63"
                  Stroke="{StaticResource snow1Rays}"
                  StrokeThickness="1" StrokeMiterLimit="10"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            </Canvas>
        </Canvas>

        <Canvas x:Name="snow2Container">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="snow2Move"/>
            </Canvas.RenderTransform>
            <Canvas>
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="snow2Rot" CenterX="24" CenterY="45"/>
                </Canvas.RenderTransform>
                <Ellipse Width="2.5" Height="2.5"
                     Canvas.Left="22.75" Canvas.Top="43.75"
                     Stroke="{StaticResource snow2Circle}"
                     StrokeThickness="1" StrokeMiterLimit="10"/>
                <Path Data="M26.17 46.25 l-1.09 -0.63 m-2.16 -1.24 l-1.09 -0.63 M24 42.5 v1.25 m0 3.75 v-1.25 m-1.08 -0.63 l-1.09 0.63 m4.34 -2.5 l-1.09 0.63"
                  Stroke="{StaticResource snow2Rays}"
                  StrokeThickness="1" StrokeMiterLimit="10"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            </Canvas>
        </Canvas>

        <Canvas x:Name="snow3Container">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="snow3Move"/>
            </Canvas.RenderTransform>
            <Canvas>
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="snow3Rot" CenterX="38" CenterY="45"/>
                </Canvas.RenderTransform>
                <Ellipse Width="2.5" Height="2.5"
                     Canvas.Left="36.75" Canvas.Top="43.75"
                     Stroke="{StaticResource snow3Circle}"
                     StrokeThickness="1" StrokeMiterLimit="10"/>
                <Path Data="M40.17 46.25 l-1.09 -0.63 m-2.16 -1.24 l-1.09 -0.63 M38 42.5 v1.25 m0 3.75 v-1.25 m-1.08 -0.63 l-1.09 0.63 m4.34 -2.5 l-1.09 0.63"
                  Stroke="{StaticResource snow3Rays}"
                  StrokeThickness="1" StrokeMiterLimit="10"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            </Canvas>
        </Canvas>
    </Canvas>
</UserControl>
