<UserControl x:Class="Weather.WeatherImages.Elements.DrizzleRaindrops"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.WeatherImages.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="drop1"
               Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
               From="1" To="-2" Duration="0:0:1.5" RepeatBehavior="Forever" />
                    <DoubleAnimation Storyboard.TargetName="drop1"
               Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
               From="-5" To="10" Duration="0:0:1.5" RepeatBehavior="Forever" />
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="drop1"
                             Storyboard.TargetProperty="(UIElement.Opacity)"
                             Duration="0:0:1.5" RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                        <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="1" />
                        <LinearDoubleKeyFrame KeyTime="0:0:1.0" Value="1" />
                        <LinearDoubleKeyFrame KeyTime="0:0:1.5" Value="0" />
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimation Storyboard.TargetName="drop2"
               Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
               From="1" To="-2" Duration="0:0:1.5" RepeatBehavior="Forever"
               BeginTime="-0:0:0.5" />
                    <DoubleAnimation Storyboard.TargetName="drop2"
               Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
               From="-5" To="10" Duration="0:0:1.5" RepeatBehavior="Forever"
               BeginTime="-0:0:0.5" />
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="drop2"
                             Storyboard.TargetProperty="(UIElement.Opacity)"
                             Duration="0:0:1.5" RepeatBehavior="Forever"
                             BeginTime="-0:0:0.5">
                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                        <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="1" />
                        <LinearDoubleKeyFrame KeyTime="0:0:1.0" Value="1" />
                        <LinearDoubleKeyFrame KeyTime="0:0:1.5" Value="0" />
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimation Storyboard.TargetName="drop3"
               Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
               From="1" To="-2" Duration="0:0:1.5" RepeatBehavior="Forever"
               BeginTime="-0:0:1" />
                    <DoubleAnimation Storyboard.TargetName="drop3"
               Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
               From="-5" To="10" Duration="0:0:1.5" RepeatBehavior="Forever"
               BeginTime="-0:0:1" />
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="drop3"
                             Storyboard.TargetProperty="(UIElement.Opacity)"
                             Duration="0:0:1.5" RepeatBehavior="Forever"
                             BeginTime="-0:0:1">
                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                        <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="1" />
                        <LinearDoubleKeyFrame KeyTime="0:0:1.0" Value="1" />
                        <LinearDoubleKeyFrame KeyTime="0:0:1.5" Value="0" />
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    <Canvas Width="64" Height="64">
        <Path x:Name="drop1"
        Data="M24.08 45.01 l-0.16 0.98"
        Stroke="{StaticResource DrizzleRaindropGradient1}"
        StrokeThickness="2"
        StrokeStartLineCap="Round"
        StrokeEndLineCap="Round"
        StrokeMiterLimit="10"
        Fill="Transparent">
            <Path.RenderTransform>
                <TranslateTransform X="0" Y="0" />
            </Path.RenderTransform>
        </Path>
        <Path x:Name="drop2"
        Data="M31.08 45.01 l-0.16 0.98"
        Stroke="{StaticResource DrizzleRaindropGradient2}"
        StrokeThickness="2"
        StrokeStartLineCap="Round"
        StrokeEndLineCap="Round"
        StrokeMiterLimit="10"
        Fill="Transparent">
            <Path.RenderTransform>
                <TranslateTransform X="0" Y="0" />
            </Path.RenderTransform>
        </Path>
        <Path x:Name="drop3"
        Data="M38.08 45.01 l-0.16 0.98"
        Stroke="{StaticResource DrizzleRaindropGradient3}"
        StrokeThickness="2"
        StrokeStartLineCap="Round"
        StrokeEndLineCap="Round"
        StrokeMiterLimit="10"
        Fill="Transparent">
            <Path.RenderTransform>
                <TranslateTransform X="0" Y="0" />
            </Path.RenderTransform>
        </Path>
    </Canvas>
</UserControl>
