<UserControl x:Class="Weather.WeatherImages.Elements.AnimatedCloud"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.WeatherImages.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="CloudTranslate" 
                                     Storyboard.TargetProperty="X"
                                     From="-3" 
                                     To="3" 
                                     Duration="0:0:3.5" 
                                     AutoReverse="True" 
                                     RepeatBehavior="Forever" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    <Rectangle Fill="{StaticResource CloudDrawing}" Width="64" Height="64">
        <Rectangle.RenderTransform>
            <TranslateTransform x:Name="CloudTranslate" X="0" Y="0" />
        </Rectangle.RenderTransform>
    </Rectangle>
</UserControl>
