<UserControl x:Class="Weather.WeatherImages.Elements.FogLine"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.WeatherImages.Elements"
             mc:Ignorable="d" 
             x:Name="root"
             d:DesignHeight="450" d:DesignWidth="800">
    <Canvas Width="64" Height="64">
        <Rectangle Canvas.Left="17" Canvas.Top="{Binding LineTopMargin, ElementName=root}"
           Width="30" Height="3"
           RadiusX="1.5" RadiusY="1.5"
           Fill="{StaticResource LineBrush}"
           RenderTransformOrigin="0.5,0.5">
            <Rectangle.RenderTransform>
                <TranslateTransform x:Name="fogLine"/>
            </Rectangle.RenderTransform>
        </Rectangle>
    </Canvas>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard BeginTime="{Binding AnimationBeginTime, ElementName=root}">
                    <DoubleAnimation Storyboard.TargetName="fogLine"
                                 Storyboard.TargetProperty="X"
                                 From="-4" To="4" Duration="0:0:2.5"
                                 AutoReverse="True" RepeatBehavior="Forever"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>