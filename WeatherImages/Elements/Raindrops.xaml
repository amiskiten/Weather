<UserControl x:Class="Weather.WeatherImages.Elements.Raindrops"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.WeatherImages.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="drop1Trans"
                                 Storyboard.TargetProperty="X"
                                 From="1" To="-2" Duration="0:0:0.7"
                                 RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="drop1Trans"
                                 Storyboard.TargetProperty="Y"
                                 From="-5" To="10" Duration="0:0:0.7"
                                 RepeatBehavior="Forever"/>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="drop1Line"
                                               Storyboard.TargetProperty="Opacity"
                                               Duration="0:0:0.7"
                                               RepeatBehavior="Forever">
                        <LinearDoubleKeyFrame Value="0" KeyTime="0%"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="33.3%"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="66.7%"/>
                        <LinearDoubleKeyFrame Value="0" KeyTime="100%"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimation Storyboard.TargetName="drop2Trans"
                                 Storyboard.TargetProperty="X"
                                 From="1" To="-2" Duration="0:0:0.7"
                                 RepeatBehavior="Forever"
                                 BeginTime="-0:0:0.4"/>
                    <DoubleAnimation Storyboard.TargetName="drop2Trans"
                                 Storyboard.TargetProperty="Y"
                                 From="-5" To="10" Duration="0:0:0.7"
                                 RepeatBehavior="Forever"
                                 BeginTime="-0:0:0.4"/>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="drop2Line"
                                               Storyboard.TargetProperty="Opacity"
                                               Duration="0:0:0.7"
                                               RepeatBehavior="Forever"
                                               BeginTime="-0:0:0.4">
                        <LinearDoubleKeyFrame Value="0" KeyTime="0%"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="33.3%"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="66.7%"/>
                        <LinearDoubleKeyFrame Value="0" KeyTime="100%"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimation Storyboard.TargetName="drop3Trans"
                                 Storyboard.TargetProperty="X"
                                 From="1" To="-2" Duration="0:0:0.7"
                                 RepeatBehavior="Forever"
                                 BeginTime="-0:0:0.2"/>
                    <DoubleAnimation Storyboard.TargetName="drop3Trans"
                                 Storyboard.TargetProperty="Y"
                                 From="-5" To="10" Duration="0:0:0.7"
                                 RepeatBehavior="Forever"
                                 BeginTime="-0:0:0.2"/>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="drop3Line"
                                               Storyboard.TargetProperty="Opacity"
                                               Duration="0:0:0.7"
                                               RepeatBehavior="Forever"
                                               BeginTime="-0:0:0.2">
                        <LinearDoubleKeyFrame Value="0" KeyTime="0%"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="33.3%"/>
                        <LinearDoubleKeyFrame Value="1" KeyTime="66.7%"/>
                        <LinearDoubleKeyFrame Value="0" KeyTime="100%"/>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    <Canvas Width="64" Height="64">
        <Line x:Name="drop1Line"
          X1="24.39" Y1="43.03" X2="23.61" Y2="47.97"
          Stroke="{StaticResource RaindropGradient1}"
          StrokeThickness="2"
          StrokeStartLineCap="Round"
          StrokeEndLineCap="Round"
          RenderTransformOrigin="0.5,0.5">
            <Line.RenderTransform>
                <TranslateTransform x:Name="drop1Trans"/>
            </Line.RenderTransform>
        </Line>
        <Line x:Name="drop2Line"
          X1="31.39" Y1="43.03" X2="30.61" Y2="47.97"
          Stroke="{StaticResource RaindropGradient2}"
          StrokeThickness="2"
          StrokeStartLineCap="Round"
          StrokeEndLineCap="Round"
          RenderTransformOrigin="0.5,0.5">
            <Line.RenderTransform>
                <TranslateTransform x:Name="drop2Trans"/>
            </Line.RenderTransform>
        </Line>
        <Line x:Name="drop3Line"
          X1="38.39" Y1="43.03" X2="37.61" Y2="47.97"
          Stroke="{StaticResource RaindropGradient3}"
          StrokeThickness="2"
          StrokeStartLineCap="Round"
          StrokeEndLineCap="Round"
          RenderTransformOrigin="0.5,0.5">
            <Line.RenderTransform>
                <TranslateTransform x:Name="drop3Trans"/>
            </Line.RenderTransform>
        </Line>
    </Canvas>
</UserControl>
