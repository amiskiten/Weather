<UserControl x:Class="Weather.Controls.Elements.UVIndexControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.Controls.Elements"
             mc:Ignorable="d"
             x:Name="root"
             d:DesignHeight="450" d:DesignWidth="800">
    <TextBlock Text="{Binding UVIndex, ElementName=root}"
               Style="{StaticResource MainTextStyle}"
               FontWeight="Bold"
               ToolTipService.InitialShowDelay="250"
               Foreground="{Binding UVIndex, ElementName=root, Converter={StaticResource UVIndexColorConverter}}"
               DataContext="{Binding ElementName=root}">
        <TextBlock.ToolTip>
            <ToolTip>
                <ToolTip.Template>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="Beige"
                            CornerRadius="12"
                            BorderBrush="Beige">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </ToolTip.Template>
                <TextBlock MaxWidth="170"
                       Margin="5"
                       Text="{Binding UVIndex, Converter={StaticResource UVIndexToolTipConverter}}"
                       FontSize="15"
                       TextWrapping="Wrap"
                       FontFamily="Roboto"/>
            </ToolTip>
        </TextBlock.ToolTip>
    </TextBlock>
</UserControl>
