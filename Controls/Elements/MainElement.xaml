<UserControl x:Class="Weather.Controls.Elements.MainElement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.Controls.Elements"
             mc:Ignorable="d" 
             x:Name="root">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding TitleText,ElementName=root}"
                                   Grid.Row="0"
                                   Style="{StaticResource TitleStyle}"/>
        <TextBlock Text="{Binding MainText,ElementName=root}"
                                   Style="{StaticResource MainTextStyle}"
                                   Grid.Row="1"/>
    </Grid>
</UserControl>
