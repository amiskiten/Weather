<UserControl x:Class="Weather.Controls.SearchControl.SearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:Weather.Controls.SearchControl" 
             d:DataContext="{d:DesignInstance Type=local:SearchViewModel}"
             mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="SearchBox"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 VerticalAlignment="Top"
                 Grid.Row="0"
                 Grid.Column="0"
                 Height="{Binding ActualHeight,ElementName=button}"/>
        <Button Background="AntiqueWhite"
                BorderBrush="AliceBlue"
                Grid.Row="0"
                x:Name="button"
                Command="{Binding NewSelectedItemCommand}"
                Grid.Column="1">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            x:Name="border"
                            CornerRadius="0,7,7,0">
                        <TextBlock Text="ОК"
                                   FontFamily="Cascadia Code"
                                   FontSize="13"
                                   Margin="4,3,4,3"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="Wheat"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="Wheat"/>
                            <Setter TargetName="border" Property="Cursor" Value="Hand"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Popup IsOpen="{Binding IsSuggestionsOpen}"
               PlacementTarget="{Binding ElementName=SearchBox}"
               Placement="Bottom"
               StaysOpen="False"
               Grid.Row="1"
               VerticalOffset="2">
            <Border BorderBrush="Gray" BorderThickness="1" Background="White" MinWidth="200">
                <ListBox ItemsSource="{Binding Suggestions}"
                         SelectedItem="{Binding SelectedSuggestion, Mode=TwoWay}"
                         MaxHeight="415"
                         x:Name="list">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="SelectionChanged">
                            <i:InvokeCommandAction Command="{Binding SelectSuggestionCommand}"
                                                   CommandParameter="{Binding SelectedItem, ElementName=list}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </ListBox>
            </Border>
        </Popup>
    </Grid>
</UserControl>
