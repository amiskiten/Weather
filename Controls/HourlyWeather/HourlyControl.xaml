<UserControl x:Class="Weather.Controls.HourlyWeather.HourlyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Weather.Controls.HourlyWeather"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             d:DataContext="{d:DesignInstance local:HourlyViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Cursor="Hand" Width="700">
        <i:Interaction.Triggers>
            <i:EventTrigger EventName="MouseLeftButtonUp">
                <i:InvokeCommandAction Command="{Binding SendWeatherDataCommand}"/>
            </i:EventTrigger>
        </i:Interaction.Triggers>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border x:Name="BorderBG"
            Background="White" 
            CornerRadius="10" 
            Grid.ColumnSpan="8"/>
        <TextBlock Grid.Column="0"
                   Text="{Binding Data.Date}"
                   Style="{StaticResource HourlyControlTextStyle}"
                   Width="80"/>
        <ContentControl Content="{Binding Data.ImageData, Converter={StaticResource ImageConverter}}"
                        Grid.Column="1"
                        Width="100"
                        Height="100"/>
        <TextBlock LineHeight="20"
                   LineStackingStrategy="BlockLineHeight"
                   Grid.Column="2"
                   Width="180"
                   Text="{Binding Data.WeatherStatus.Description}"
                   Style="{StaticResource HourlyControlTextStyle}"
                   TextWrapping="Wrap"/>
        <TextBlock Width="76"
                   Grid.Column="3"
                   Text="{Binding Data.Temperature, StringFormat='\{0}°C'}"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="18"
                   FontFamily="Roboto"/>
        <TextBlock Width="76"
                   Grid.Column="4"
                   Text="{Binding Data.ApparentTemperature, StringFormat='\{0}°C'}"
                   Style="{StaticResource HourlyControlTextStyle}"/>
        <TextBlock Width="76"
                   Grid.Column="5"
                   Text="{Binding Data.WindSpeed, StringFormat='\{0}м/с'}"
                   Style="{StaticResource HourlyControlTextStyle}"/>
        <TextBlock  Width="76"
                    Grid.Column="6"
                    Text="{Binding Data.Humidity, StringFormat='\{0}%'}"
                    Style="{StaticResource HourlyControlTextStyle}"/>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="MouseLeftButtonDown">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetName="BorderBG"
                                    Storyboard.TargetProperty="Background.Color"
                                    To="#e6e6e6"
                                    Duration="0:0:0:0.3"/>
                        <ColorAnimation Storyboard.TargetName="BorderBG"
                                    Storyboard.TargetProperty="Background.Color"
                                    To="White"
                                    Duration="0:0:0:0.3"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
    </Grid>
</UserControl>