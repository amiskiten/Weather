<Window x:Class="Weather.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Weather"
        xmlns:Daily="clr-namespace:Weather.Controls.DailyWeather"
        xmlns:Hourly="clr-namespace:Weather.Controls.HourlyWeather"
        xmlns:Location="clr-namespace:Weather.Controls.LocationInfo"
        xmlns:Current="clr-namespace:Weather.Controls.CurrentWeather"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:Sticky="clr-namespace:Weather.Controls.StickyControl"
        xmlns:Search="clr-namespace:Weather.Controls.SearchControl"
        d:DataContext="{d:DesignInstance Type=local:MainViewModel}"
        Title="{Binding WindowTitle}"
        WindowStartupLocation="CenterScreen"
        Background="#FFF1F1F1"
        mc:Ignorable="d"
        Height="700" 
        Width="1150">
    <Window.Icon>
        <BitmapImage UriSource="pack://application:,,,/StaticData/icon.ico"/>
    </Window.Icon>
    <ScrollViewer>
        <i:Interaction.Behaviors>
            <Sticky:StickyBehavior TargetElement="{Binding ElementName=CurrentControlPart}"
                                  IsSticky="{Binding IsCurrentSticky, Mode=TwoWay}"/>
        </i:Interaction.Behaviors>
        <Grid Margin="7,7,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Background="White"
                    CornerRadius="24,24,0,0"
                    BorderBrush="LightGray"
                    Grid.Row="0"
                    Grid.ColumnSpan="3"/>
            <Location:LocationControl DataContext="{Binding LocationData}"
                                  Grid.Row="0"
                                  Grid.Column="1"/>
            <StackPanel Grid.Column="0"
                        Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="5,5,0,0">
                <StackPanel Grid.Column="0"
                            Margin="10,0,0,10">
                    <TextBlock Text="Выберите город&#x0A;(нажмите ОК для подтверждения)"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="14"
                               FontFamily="Roboto"
                               Margin="0,0,0,0"/>
                    <Search:SearchControl Width="170"
                                          DataContext="{Binding SearchData}"/>
                    <TextBlock Text="Выберите день"
                               HorizontalAlignment="Center"
                               FontSize="14"
                               FontFamily="Roboto"
                               Margin="0,5,0,4"/>
                    <ComboBox Grid.Column="2" 
                              Grid.Row="0"
                              ItemsSource="{Binding DaysList}" 
                              SelectedItem="{Binding SelectedDay, Mode=TwoWay}"
                              MaxWidth="170"
                              Height="24"
                              HorizontalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Left"
                        Command="{Binding UpdateDataCommand}"
                        Background="#FFFFF9E2"
                        Grid.Column="1"
                        Margin="15,0,0,0"
                        MaxHeight="24" 
                        BorderBrush="#FFFFE68D"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    x:Name="border"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    CornerRadius="7">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#FFFFF0B7"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#FFFFC700"/>
                                    <Setter TargetName="border" Property="Cursor" Value="Hand"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Background" Value="#FFF5F5F5"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#FFBDBDBD"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="Обновить данные"
                               FontFamily="Cascadia Code"
                               FontSize="14"
                               Margin="5,3.25,5,3.25"/>
                </Button>
            </StackPanel>
            <Grid x:Name="CurrentControlPart"
                  Grid.ColumnSpan="3"
                  Grid.Row="1"
                  Panel.ZIndex="1">
                <Border Background="White"
                        CornerRadius="0,0,24,24"
                        BorderBrush="LightGray"
                        Grid.Row="0"
                        Grid.ColumnSpan="3"/>
                <Current:CurrentControl DataContext="{Binding CurrentData}"
                                        Grid.ColumnSpan="3"
                                        Grid.Row="1"/>
            </Grid>
            <Grid Grid.Row="2"
                  Grid.ColumnSpan="3"
                  Margin="0,5,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="410"/>
                    <ColumnDefinition Width="76"/>
                    <ColumnDefinition Width="76"/>
                    <ColumnDefinition Width="76"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="#FFFBF9FF"
                        CornerRadius="10"
                        BorderBrush="LightBlue"
                        Grid.ColumnSpan="6"/>
                <TextBlock Grid.Column="0"
                           Text="{Binding SelectedDay, StringFormat='\Погода на {0}'}"
                           FontSize="20"
                           FontFamily="Roboto"
                           TextAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
                <TextBlock Grid.Column="1"
                           Text="погода"
                           Style="{StaticResource TitleStyle}"
                           TextAlignment="Left"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="ощущается"
                           Style="{StaticResource TitleStyle}"
                           TextAlignment="Left"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3"
                           Style="{StaticResource TitleStyle}"                           
                           TextAlignment="Left"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center">
                    ветер,
                    <LineBreak/>
                    м/с
                </TextBlock>
                <TextBlock Grid.Column="4"
                           Text="влажность"
                           Style="{StaticResource TitleStyle}"
                           TextAlignment="Left"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Grid>
            <ItemsControl Grid.Column="0"
                          Grid.Row="3"
                          Grid.ColumnSpan="3"
                          ItemsSource="{Binding HourlyData}"
                          Margin="0,10,0,5"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Hourly:HourlyControl Margin="0,0,0,5"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <Border Grid.Row="4"
                    Grid.ColumnSpan="3"
                    Background="White"
                    BorderBrush="LightGray"
                    CornerRadius="24"/>
            <Daily:DailyControl DataContext="{Binding DailyData}"
                            Grid.ColumnSpan="3"
                            Grid.Row="4"
                                Margin="0,0,0,20"/>
        </Grid>
    </ScrollViewer>
</Window>
